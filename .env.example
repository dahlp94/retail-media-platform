# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO

# API server (FastAPI / Uvicorn)
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated origins for CORS (e.g. http://localhost:8501 for Streamlit)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=retail_media
POSTGRES_PASSWORD=changeme
POSTGRES_DB=retail_media

# Full URL (optional; overrides discrete POSTGRES_* if your code prefers a single DSN)
DATABASE_URL=postgresql://retail_media:changeme@localhost:5432/retail_media

# -----------------------------------------------------------------------------
# MLflow (optional; point to server or local ./mlruns)
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=file:./mlruns
# MLFLOW_TRACKING_URI=http://localhost:5000
